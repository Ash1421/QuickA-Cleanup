<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="QuickA_Cleanup.GUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED"/>
            <SolidColorBrush x:Key="AccentBrushSubtle" Color="#7C3AED" Opacity="0.14"/>
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="White"/>

            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#7C3AED"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#7C3AED"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#7C3AED"/>

            <Style x:Key="AccentFilledButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AccentForegroundBrush}"/>
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
