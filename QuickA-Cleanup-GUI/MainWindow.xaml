<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="QuickA_Cleanup.GUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiex="using:WinUIEx"
    xmlns:local="using:QuickA_Cleanup.GUI"
    Title="QuickA-Cleanup"
    Width="900" Height="640"
    MinWidth="760" MinHeight="520"
    PersistenceId="MainWindow">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Margin="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                <Image Source="ms-appx:///Assets/AppIcon.png" Width="18" Height="18" Stretch="Uniform"/>
                <TextBlock Text="QuickA-Cleanup" Style="{StaticResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3,6,2" VerticalAlignment="Center">
                    <TextBlock x:Name="VersionBadge" Text="V3.0.0" FontSize="11"
                               LineHeight="14" LineStackingStrategy="BlockLineHeight" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontFamily="Cascadia Mono, Consolas"/>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Ellipse x:Name="DotBloat" Width="7" Height="7"/>
                    <TextBlock Text="Bloat" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="DotTestpinGroup" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Visibility="Collapsed">
                    <Ellipse x:Name="DotTestpin" Width="7" Height="7"/>
                    <TextBlock Text="Test pins" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Ellipse x:Name="DotError" Width="7" Height="7"/>
                    <TextBlock Text="Errors" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnUpdateAvailable" Click="BtnUpdateAvailable_Click"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Visibility="Collapsed" ToolTipService.ToolTip="Update available — open Settings">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"/>
                        <TextBlock x:Name="TxtUpdateAvailable" Text="Update available" FontSize="11"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button x:Name="BtnSettings" Grid.Column="1" Click="BtnSettings_Click"
                    Background="Transparent" BorderThickness="0"
                    Padding="6" CornerRadius="4"
                    VerticalAlignment="Center" Margin="0,0,150,0"
                    ToolTipService.ToolTip="Settings">
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE713;" FontSize="15"/>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="Quick Access Navigation Pane" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Name="TxtStatus" Text="Ready — click Scan to begin."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ProgressBar x:Name="ScanProgressBar" IsIndeterminate="True" Width="220"
                                 HorizontalAlignment="Left" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkDryRun" Content="Dry Run"
                              ToolTipService.ToolTip="Preview removals without touching the registry"/>
                    <CheckBox x:Name="ChkBackup" Content="Backup" IsChecked="True"
                              ToolTipService.ToolTip="Save a .reg backup file before removing"/>
                    <Button x:Name="BtnScan" Content="Scan" Click="BtnScan_Click"
                            Style="{StaticResource AccentFilledButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="20,14,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="12,0,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="NAME" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="GUID" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="TYPE" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
            </Grid>

            <Border Grid.Row="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <ListView x:Name="ItemsList" SelectionMode="None" Padding="4"
                              ItemsSource="{x:Bind Items}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ItemViewModel">
                                <Grid Padding="10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>

                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Margin="4,0,8,0"/>

                                    <TextBlock Grid.Column="2" Text="{x:Bind Guid}" VerticalAlignment="Center"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Border Grid.Column="3" Background="{x:Bind TagBackground}" CornerRadius="4"
                                            Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TagLabel}" Foreground="{x:Bind TagForeground}" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="No items to show" Style="{StaticResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click Scan to find Quick Access items"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Select All" Click="BtnSelectAll_Click"/>
                    <Button Content="Deselect All" Click="BtnDeselectAll_Click"/>
                    <TextBlock x:Name="TxtSelectionCount" Text="0 selected" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="BtnRemove" Content="Remove Selected" Click="BtnRemove_Click"
                        Style="{StaticResource DangerButtonStyle}" IsEnabled="False"/>
            </Grid>
        </Border>

        <Grid x:Name="ProgressOverlay" Grid.RowSpan="4" Background="{ThemeResource SmokeFillColorDefaultBrush}" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtProgress" Text="Working..." Style="{StaticResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtProgressSub" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</winuiex:WindowEx>
