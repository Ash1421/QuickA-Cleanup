<Window x:Class="QuickA_Cleanup.GUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="BgCard"        Color="#1C1C22"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#151519"/>
        <SolidColorBrush x:Key="BgHover"       Color="#23232B"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#10B981"/>
        <SolidColorBrush x:Key="AccentCyan"    Color="#06B6D4"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#EF4444"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F1F1F3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B8B9E"/>
        <SolidColorBrush x:Key="BorderSubtle"  Color="#2A2A35"/>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LevelButton" TargetType="ToggleButton">
            <Setter Property="FontFamily"      Value="Cascadia Code, Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"      Value="{StaticResource BgSurface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#2A1A4E"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="{StaticResource AccentPurple}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="3" Background="#3A3A4E" Margin="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Full-window frosted overlay -->
    <Grid>
        <!-- Semi-transparent backdrop — clicking it closes the modal -->
        <Rectangle Fill="#BB000000" MouseDown="Backdrop_MouseDown"/>

        <!-- Centered settings card -->
        <Border x:Name="SettingsCard"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="520" MaxWidth="640"
                MouseDown="Card_MouseDown">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Modal title bar -->
                <Border Grid.Row="0" CornerRadius="14,14,0,0"
                        Background="{StaticResource BgSurface}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="14" Foreground="{StaticResource AccentPurple}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Settings" Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="✕" Click="BtnClose_Click" Width="30" Height="26"
                                HorizontalAlignment="Right"
                                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                FontFamily="Segoe UI" FontSize="13" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Settings content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20,16,20,20">
                    <StackPanel>

                        <!-- ── Testing ──────────────────────────────────── -->
                        <TextBlock Text="TESTING" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <Border Background="{StaticResource BgSurface}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                Padding="16,14" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Test Registry Entries"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="Medium"/>
                                    <TextBlock x:Name="TxtTestpinStatus"
                                               Text="Checking..."
                                               Foreground="{StaticResource TextSecondary}"
                                               FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="BtnDownloadTestpins"
                                            Content="⬇  Download" Click="BtnDownloadTestpins_Click"
                                            Style="{StaticResource FlatButton}"
                                            Background="{StaticResource BgHover}"
                                            Foreground="{StaticResource TextSecondary}"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="BtnInstallTestpins"
                                            Content="⚡  Install" Click="BtnInstallTestpins_Click"
                                            Style="{StaticResource FlatButton}"
                                            Background="{StaticResource AccentPurple}"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="BtnRemoveTestpins"
                                            Content="🗑  Remove" Click="BtnRemoveTestpins_Click"
                                            Style="{StaticResource FlatButton}"
                                            Background="{StaticResource AccentRed}"
                                            Foreground="White"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtTestStatus" Text=""
                                   Foreground="{StaticResource AccentGreen}"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Margin="4,4,0,12"/>

                        <!-- ── Logs ─────────────────────────────────────── -->
                        <TextBlock Text="LOGS" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,8,0,10"/>

                        <!-- Log level filter -->
                        <Border Background="{StaticResource BgSurface}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                Padding="16,12" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Minimum Log Level"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="Filter which entries appear in the log viewer"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <!-- Level toggle buttons -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ToggleButton x:Name="BtnLevelTrace" Content="TRACE"
                                                  Style="{StaticResource LevelButton}"
                                                  IsChecked="True"
                                                  Click="LevelButton_Click" Tag="Trace"
                                                  Margin="0,0,4,0"/>
                                    <ToggleButton x:Name="BtnLevelDev"   Content="DEV"
                                                  Style="{StaticResource LevelButton}"
                                                  Click="LevelButton_Click" Tag="Dev"
                                                  Margin="0,0,4,0"/>
                                    <ToggleButton x:Name="BtnLevelWarn"  Content="WARN"
                                                  Style="{StaticResource LevelButton}"
                                                  Click="LevelButton_Click" Tag="Warn"
                                                  Margin="0,0,4,0"/>
                                    <ToggleButton x:Name="BtnLevelError" Content="ERROR"
                                                  Style="{StaticResource LevelButton}"
                                                  Click="LevelButton_Click" Tag="Error"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Expandable log viewer -->
                        <Border Background="{StaticResource BgSurface}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                Margin="0,0,0,0">
                            <Expander x:Name="LogExpander" IsExpanded="False">
                                <Expander.Header>
                                    <Grid Width="460">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="4,10">
                                            <TextBlock Text="Log Viewer"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       FontWeight="Medium" VerticalAlignment="Center"/>
                                            <Border Background="#2A2A35" CornerRadius="4"
                                                    Padding="6,2" Margin="8,0,0,0">
                                                <TextBlock x:Name="TxtLogCount" Text="0 entries"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Clear"
                                                Click="BtnClearLog_Click"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextSecondary}"
                                                FontFamily="Segoe UI" FontSize="11"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="0,0,4,0" Padding="8,4"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Expander.Header>

                                <Border BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="0,1,0,0">
                                    <ScrollViewer x:Name="LogScrollViewer"
                                                  Height="200"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="12,8">
                                        <ItemsControl x:Name="LogList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Formatted}"
                                                               Foreground="{Binding LevelColour}"
                                                               FontFamily="Cascadia Code, Consolas"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,1"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Expander>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
